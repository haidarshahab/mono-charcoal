export const translations: Record<Language, TranslationStrings> = {
  en,
  ar,
  de,
  fr,
  tr,
  ru,
  ja,
};

export const getTranslation = (lang: Language): TranslationStrings => {
  return translations[lang] || translations.en;
};

export default translations;